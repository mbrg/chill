#!/usr/bin/env bash
# Pre-commit hook: reject commits containing AI attribution
set -euo pipefail

# Check staged diff for attribution strings
if git diff --cached --diff-filter=d -U0 | grep -qiE "claude|anthropic|co-authored-by|generated.*(by|with).*ai"; then
    echo "ERROR: Commit contains AI attribution. Remove it and try again."
    exit 1
fi

# Check commit message (available via prepare-commit-msg, but also catch amends)
if [ -f "$1" ] 2>/dev/null; then
    if grep -qiE "claude|anthropic|co-authored-by|generated.*(by|with).*ai" "$1"; then
        echo "ERROR: Commit message contains AI attribution. Remove it and try again."
        exit 1
    fi
fi

exit 0
